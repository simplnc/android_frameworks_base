<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/oneplus_lockscreen_container"
    android:gravity="start|center"
    android:layout_gravity="start|center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:visibility="visible"
    xmlns:android="http://schemas.android.com/apk/res/android">
    
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <TextClock
            android:textSize="72.0dip"
            android:textColor="@android:color/white"
            android:fontFamily="@*android:string/config_clockFontFamily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAlignment="center"
            android:format12Hour="EEEE"
            android:format24Hour="EEEE"
            android:shadowColor="@android:color/black"
            android:shadowRadius="2.0"
            android:shadowDx="1.0"
            android:shadowDy="1.0"
            android:textStyle="bold"/>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            
            <TextView
                android:textSize="42sp"
                android:textColor="@android:color/white"
                android:id="@+id/summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:text="Basha Mobile"
                android:singleLine="true"
                android:textAlignment="center"
                android:shadowColor="@android:color/black"
                android:shadowRadius="2.0"
                android:shadowDx="1.0"
                android:shadowDy="1.0"
                android:textStyle="bold"/>
        </LinearLayout>
        
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">
            
            <TextClock
                android:textSize="96.0dip"
                android:textColor="@android:color/system_accent1_600"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:singleLine="true"
                android:format12Hour="hh"
                android:format24Hour="HH"
                android:shadowColor="@android:color/black"
                android:shadowRadius="2.0"
                android:shadowDx="1.0"
                android:shadowDy="1.0"
                android:textStyle="bold"/>
            
            <TextClock
                android:textSize="96.0dip"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:singleLine="true"
                android:format12Hour=":mm"
                android:format24Hour=":mm"
                android:shadowColor="@android:color/black"
                android:shadowRadius="2.0"
                android:shadowDx="1.0"
                android:shadowDy="1.0"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextClock
            android:id="@+id/oos_date"
            android:textSize="40dp"
            android:textColor="@android:color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@*android:string/config_clockFontFamily"
            android:singleLine="true"
            android:textAlignment="center"
            android:format12Hour="MMMM dd"
            android:format24Hour="MMMM dd"
            android:shadowColor="@android:color/black"
            android:shadowRadius="2.0"
            android:shadowDx="1.0"
            android:shadowDy="1.0"
            android:textStyle="bold"/>

        
    </LinearLayout>
</LinearLayout>
