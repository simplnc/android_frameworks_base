<?xml version="1.0" encoding="utf-8"?>
<!-- OnePlus-inspired ambient display clock style -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Ambient clock background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- Ambient clock text shadow -->
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <size android:width="120dp" android:height="30dp" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- Ambient clock text -->
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="@color/ambient_display_clock_primary" />
            <size android:width="120dp" android:height="30dp" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
