<?xml version="1.0" encoding="utf-8"?>
<!-- Enhanced signal strength icon with dynamic colors -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Excellent signal -->
    <item android:state_signal_excellent="true">
        <layer-list>
            <item android:drawable="@drawable/stat_sys_signal_4" 
                  android:tint="@color/status_bar_signal_excellent" />
        </layer-list>
    </item>
    
    <!-- Good signal -->
    <item android:state_signal_good="true">
        <layer-list>
            <item android:drawable="@drawable/stat_sys_signal_3" 
                  android:tint="@color/status_bar_signal_good" />
        </layer-list>
    </item>
    
    <!-- Fair signal -->
    <item android:state_signal_fair="true">
        <layer-list>
            <item android:drawable="@drawable/stat_sys_signal_2" 
                  android:tint="@color/status_bar_signal_fair" />
        </layer-list>
    </item>
    
    <!-- Poor signal -->
    <item android:state_signal_poor="true">
        <layer-list>
            <item android:drawable="@drawable/stat_sys_signal_1" 
                  android:tint="@color/status_bar_signal_poor" />
        </layer-list>
    </item>
    
    <!-- Default state -->
    <item>
        <layer-list>
            <item android:drawable="@drawable/stat_sys_signal_4" 
                  android:tint="@android:color/white" />
        </layer-list>
    </item>
</selector>
