<?xml version="1.0" encoding="utf-8"?>
<!-- Nothing Phone-inspired lock screen shortcut background -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/lock_screen_shortcut_press" />
            <stroke 
                android:width="1dp" 
                android:color="@color/lock_screen_clock_nothing_primary" />
            <corners android:radius="12dp" />
            <size android:width="60dp" android:height="60dp" />
        </shape>
    </item>
    
    <!-- Hover state -->
    <item android:state_hovered="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/lock_screen_shortcut_hover" />
            <stroke 
                android:width="1dp" 
                android:color="@color/lock_screen_clock_nothing_primary" />
            <corners android:radius="12dp" />
            <size android:width="60dp" android:height="60dp" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke 
                android:width="1dp" 
                android:color="@color/lock_screen_clock_nothing_primary" />
            <corners android:radius="12dp" />
            <size android:width="60dp" android:height="60dp" />
        </shape>
    </item>
</selector>
