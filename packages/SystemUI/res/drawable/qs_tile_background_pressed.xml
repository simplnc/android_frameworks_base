<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <corners android:radius="@dimen/qs_corner_radius" />
    <!-- Pressed state: darker gradient for tactile feedback -->
    <gradient
        android:startColor="#E8E8E8"
        android:centerColor="#E0E0E0"
        android:endColor="#D8D8D8"
        android:angle="135" />
    <!-- Enhanced border for pressed state -->
    <stroke android:width="1dp" android:color="#2A000000" />
    <size android:width="0dp" android:height="0dp" />
</shape>
