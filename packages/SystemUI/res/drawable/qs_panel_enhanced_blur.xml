<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base transparent layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="@dimen/qs_corner_radius" />
        </shape>
    </item>
    
    <!-- Subtle inner glow for depth -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#08FFFFFF" />
            <corners android:radius="@dimen/qs_corner_radius" />
            <stroke android:width="1dp" android:color="#12FFFFFF" />
        </shape>
    </item>
    
    <!-- Very light overlay for better contrast -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#05FFFFFF" />
            <corners android:radius="@dimen/qs_corner_radius" />
        </shape>
    </item>
</layer-list>




