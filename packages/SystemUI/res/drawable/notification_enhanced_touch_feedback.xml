<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:radius="32dp"
    android:color="?android:attr/colorControlHighlight">
    
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    
    <item android:id="@android:id/background">
        <selector>
            <item android:state_pressed="true">
                <layer-list>
                    <!-- Shadow for depression effect -->
                    <item android:top="3dp" android:left="3dp">
                        <shape android:shape="rectangle">
                            <solid android:color="#30000000"/>
                            <corners android:radius="18dp"/>
                        </shape>
                    </item>
                    <!-- Main pressed background -->
                    <item android:top="1dp" android:left="1dp">
                        <shape android:shape="rectangle">
                            <solid android:color="?android:attr/colorControlHighlight"/>
                            <corners android:radius="18dp"/>
                            <stroke android:width="1dp" android:color="?android:attr/colorAccent" android:alpha="0.5"/>
                        </shape>
                    </item>
                </layer-list>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent"/>
                    <corners android:radius="18dp"/>
                </shape>
            </item>
        </selector>
    </item>
</ripple>
