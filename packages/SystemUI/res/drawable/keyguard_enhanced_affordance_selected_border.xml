<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <!-- Enhanced selected state with accent color -->
            <stroke 
                android:width="3dp"
                android:color="?android:attr/colorAccent" />
                
            <!-- Size constraints -->
            <size 
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
    
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <!-- Pressed state with lighter accent -->
            <stroke 
                android:width="2dp"
                android:color="?android:attr/colorAccent"
                android:alpha="0.7" />
                
            <!-- Size constraints -->
            <size 
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
    
    <!-- Default state - invisible border -->
    <item>
        <shape android:shape="oval">
            <stroke 
                android:width="0dp"
                android:color="@android:color/transparent" />
                
            <!-- Size constraints -->
            <size 
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
</selector>
