<?xml version="1.0" encoding="utf-8"?>
<!-- Nothing Phone-inspired ambient display clock style -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Ambient clock background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/lock_screen_clock_nothing_secondary" />
            <corners android:radius="6dp" />
            <stroke 
                android:width="1dp" 
                android:color="@color/lock_screen_clock_nothing_primary" />
        </shape>
    </item>
    
    <!-- Ambient clock glow effect -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2000FF41" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    
    <!-- Ambient clock text -->
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="@color/lock_screen_clock_nothing_primary" />
            <size android:width="100dp" android:height="25dp" />
            <corners android:radius="5dp" />
        </shape>
    </item>
</layer-list>
