<?xml version="1.0" encoding="utf-8"?>
<!-- Nothing Phone-inspired ambient display notification preview -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Notification background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/lock_screen_clock_nothing_secondary" />
            <corners android:radius="8dp" />
            <stroke 
                android:width="1dp" 
                android:color="@color/lock_screen_clock_nothing_primary" />
        </shape>
    </item>
    
    <!-- Notification glow effect -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2000FF41" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- Notification content area -->
    <item android:top="1dp" android:left="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/lock_screen_clock_nothing_secondary" />
            <corners android:radius="7dp" />
        </shape>
    </item>
</layer-list>
