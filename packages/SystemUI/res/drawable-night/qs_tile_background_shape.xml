<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <corners android:radius="@dimen/qs_corner_radius" />
    <!-- Dark mode: subtle gradient for depth -->
    <gradient
        android:startColor="#2A2A2A"
        android:centerColor="#262626"
        android:endColor="#222222"
        android:angle="135" />
    <!-- Slight surface tint to emulate layered surfaces -->
    <size android:width="0dp" android:height="0dp" />
</shape>
