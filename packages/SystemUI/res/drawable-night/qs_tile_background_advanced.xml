<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Advanced Shadow Layer for Dark Mode -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#60000000"
                android:centerColor="#30000000"
                android:endColor="#20000000" />
            <corners android:radius="@dimen/qs_corner_radius" />
        </shape>
    </item>
    
    <!-- Main Background -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#2A2A2A"
                android:centerColor="#262626"
                android:endColor="#222222" />
            <corners android:radius="@dimen/qs_corner_radius" />
            <stroke
                android:width="1dp"
                android:color="#404040" />
        </shape>
    </item>
    
    <!-- Highlight Layer -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#20FFFFFF"
                android:centerColor="#10FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="@dimen/qs_corner_radius" />
        </shape>
    </item>
</layer-list>
