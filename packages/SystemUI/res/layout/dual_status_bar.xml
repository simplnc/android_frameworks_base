<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:systemui="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:id="@+id/dual_status_bar_container"
    android:focusable="false"
    android:descendantFocusability="afterDescendants">

    <!-- Primary Status Bar (Top) -->
    <com.android.systemui.statusbar.phone.PhoneStatusBarView
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height"
        android:id="@+id/primary_status_bar"
        android:orientation="vertical"
        android:focusable="false"
        android:descendantFocusability="afterDescendants"
        android:accessibilityPaneTitle="@string/status_bar">

        <ImageView
            android:id="@+id/primary_notification_lights_out"
            android:layout_width="@dimen/status_bar_icon_size_sp"
            android:layout_height="match_parent"
            android:paddingStart="@dimen/status_bar_padding_start"
            android:paddingBottom="2dip"
            android:src="@drawable/ic_sysbar_lights_out_dot_small"
            android:scaleType="center"
            android:visibility="gone" />

        <LinearLayout android:id="@+id/primary_status_bar_contents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="@dimen/status_bar_padding_start"
            android:paddingEnd="@dimen/status_bar_padding_end"
            android:paddingTop="@dimen/status_bar_padding_top"
            android:orientation="horizontal">

            <!-- Primary Status Bar Start Side -->
            <FrameLayout
                android:id="@+id/primary_status_bar_start_side_container"
                android:layout_height="match_parent"
                android:layout_width="0dp"
                android:clipChildren="false"
                android:layout_weight="1">

                <FrameLayout
                    android:id="@+id/primary_status_bar_start_side_content"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical|start"
                    android:clipChildren="false">

                    <include layout="@layout/heads_up_status_bar_layout" />

                    <LinearLayout
                        android:id="@+id/primary_status_bar_start_side_except_heads_up"
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"
                        android:layout_gravity="center_vertical|start"
                        android:clipChildren="false">

                        <ViewStub
                            android:id="@+id/primary_operator_name_stub"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout="@layout/operator_name" />

                        <com.android.systemui.statusbar.policy.Clock
                            android:id="@+id/primary_clock"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/status_bar_system_icons_height"
                            android:layout_gravity="center_vertical"
                            android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                            android:singleLine="true"
                            android:paddingStart="@dimen/status_bar_left_clock_starting_padding"
                            android:paddingEnd="@dimen/status_bar_left_clock_end_padding"
                            android:gravity="center_vertical|start"
                            systemui:isStatusBar="true" />

                        <include layout="@layout/ongoing_activity_chip"
                            android:id="@+id/primary_ongoing_activity_chip_primary"/>

                        <include layout="@layout/ongoing_activity_chip"
                            android:id="@+id/primary_ongoing_activity_chip_secondary"
                            android:visibility="gone"/>

                        <com.android.systemui.statusbar.AlphaOptimizedFrameLayout
                            android:id="@+id/primary_notification_icon_area"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:clipChildren="false"/>

                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>

            <!-- Primary Status Bar Center Space -->
            <android.widget.Space
                android:id="@+id/primary_cutout_space_view"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:gravity="center_horizontal|center_vertical" />

            <!-- Primary Status Bar End Side -->
            <FrameLayout
                android:id="@+id/primary_status_bar_end_side_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipChildren="false">

                <com.android.keyguard.AlphaOptimizedLinearLayout
                    android:id="@+id/primary_status_bar_end_side_content"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|end"
                    android:clipChildren="false">

                    <include
                        android:id="@+id/primary_user_switcher_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/status_bar_user_chip_end_margin"
                        layout="@layout/status_bar_user_chip_container" />

                    <include layout="@layout/system_icons"
                         android:layout_gravity="center_vertical"
                         android:layout_width="wrap_content"
                         android:layout_height="@dimen/status_bar_system_icons_height" />

                </com.android.keyguard.AlphaOptimizedLinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- Primary Status Bar Centered Area -->
        <com.android.keyguard.AlphaOptimizedLinearLayout
            android:id="@+id/primary_centered_area"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="@dimen/status_bar_padding_top">
            <com.android.systemui.statusbar.policy.Clock
                android:id="@+id/primary_clock_center"
                android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/status_bar_system_icons_height"
                android:singleLine="true"
                android:gravity="center"
                android:visibility="gone"
                systemui:isStatusBar="true" />
        </com.android.keyguard.AlphaOptimizedLinearLayout>

    </com.android.systemui.statusbar.phone.PhoneStatusBarView>

    <!-- Secondary Status Bar (Bottom) -->
    <com.android.systemui.statusbar.phone.PhoneStatusBarView
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height"
        android:id="@+id/secondary_status_bar"
        android:orientation="vertical"
        android:focusable="false"
        android:descendantFocusability="afterDescendants"
        android:accessibilityPaneTitle="@string/status_bar_secondary">

        <ImageView
            android:id="@+id/secondary_notification_lights_out"
            android:layout_width="@dimen/status_bar_icon_size_sp"
            android:layout_height="match_parent"
            android:paddingStart="@dimen/status_bar_padding_start"
            android:paddingBottom="2dip"
            android:src="@drawable/ic_sysbar_lights_out_dot_small"
            android:scaleType="center"
            android:visibility="gone" />

        <LinearLayout android:id="@+id/secondary_status_bar_contents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="@dimen/status_bar_padding_start"
            android:paddingEnd="@dimen/status_bar_padding_end"
            android:paddingTop="@dimen/status_bar_padding_top"
            android:orientation="horizontal">

            <!-- Secondary Status Bar Start Side -->
            <FrameLayout
                android:id="@+id/secondary_status_bar_start_side_container"
                android:layout_height="match_parent"
                android:layout_width="0dp"
                android:clipChildren="false"
                android:layout_weight="1">

                <FrameLayout
                    android:id="@+id/secondary_status_bar_start_side_content"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical|start"
                    android:clipChildren="false">

                    <LinearLayout
                        android:id="@+id/secondary_status_bar_start_side_except_heads_up"
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"
                        android:layout_gravity="center_vertical|start"
                        android:clipChildren="false">

                        <ViewStub
                            android:id="@+id/secondary_operator_name_stub"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout="@layout/operator_name" />

                        <com.android.systemui.statusbar.policy.Clock
                            android:id="@+id/secondary_clock"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/status_bar_system_icons_height"
                            android:layout_gravity="center_vertical"
                            android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                            android:singleLine="true"
                            android:paddingStart="@dimen/status_bar_left_clock_starting_padding"
                            android:paddingEnd="@dimen/status_bar_left_clock_end_padding"
                            android:gravity="center_vertical|start"
                            systemui:isStatusBar="true" />

                        <com.android.systemui.statusbar.AlphaOptimizedFrameLayout
                            android:id="@+id/secondary_notification_icon_area"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:clipChildren="false"/>

                        <!-- Secondary Status Bar Network Traffic -->
                        <com.android.systemui.statusbar.LineageStatusBarItemHolder
                            android:id="@+id/secondary_network_traffic_holder_start"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layoutDirection="ltr"
                            android:gravity="center"
                            android:paddingStart="4dp">

                            <org.lineageos.internal.statusbar.NetworkTraffic
                                android:id="@+id/secondary_network_traffic_start"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:maxLines="2"
                                android:gravity="center" />

                        </com.android.systemui.statusbar.LineageStatusBarItemHolder>

                    </LinearLayout>
                </FrameLayout>
            </FrameLayout>

            <!-- Secondary Status Bar Center Space -->
            <android.widget.Space
                android:id="@+id/secondary_cutout_space_view"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:gravity="center_horizontal|center_vertical" />

            <!-- Secondary Status Bar Center Network Traffic -->
            <com.android.systemui.statusbar.LineageStatusBarItemHolder
                android:id="@+id/secondary_network_traffic_holder_center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layoutDirection="ltr"
                android:gravity="center">

                <org.lineageos.internal.statusbar.NetworkTraffic
                    android:id="@+id/secondary_network_traffic_center"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:maxLines="2"
                    android:gravity="center" />

            </com.android.systemui.statusbar.LineageStatusBarItemHolder>

            <!-- Secondary Status Bar End Side -->
            <FrameLayout
                android:id="@+id/secondary_status_bar_end_side_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipChildren="false">

                <com.android.keyguard.AlphaOptimizedLinearLayout
                    android:id="@+id/secondary_status_bar_end_side_content"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|end"
                    android:clipChildren="false">

                    <!-- Secondary Status Bar End Network Traffic -->
                    <com.android.systemui.statusbar.LineageStatusBarItemHolder
                        android:id="@+id/secondary_network_traffic_holder_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layoutDirection="ltr"
                        android:gravity="center"
                        android:paddingLeft="2dp">

                        <org.lineageos.internal.statusbar.NetworkTraffic
                            android:id="@+id/secondary_network_traffic_end"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:maxLines="2"
                            android:gravity="center" />

                    </com.android.systemui.statusbar.LineageStatusBarItemHolder>

                    <include
                        android:id="@+id/secondary_user_switcher_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/status_bar_user_chip_end_margin"
                        layout="@layout/status_bar_user_chip_container" />

                    <include layout="@layout/system_icons"
                         android:layout_gravity="center_vertical"
                         android:layout_width="wrap_content"
                         android:layout_height="@dimen/status_bar_system_icons_height" />

                </com.android.keyguard.AlphaOptimizedLinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- Secondary Status Bar Centered Area -->
        <com.android.keyguard.AlphaOptimizedLinearLayout
            android:id="@+id/secondary_centered_area"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="@dimen/status_bar_padding_top">
            <com.android.systemui.statusbar.policy.Clock
                android:id="@+id/secondary_clock_center"
                android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/status_bar_system_icons_height"
                android:singleLine="true"
                android:gravity="center"
                android:visibility="gone"
                systemui:isStatusBar="true" />
        </com.android.keyguard.AlphaOptimizedLinearLayout>

    </com.android.systemui.statusbar.phone.PhoneStatusBarView>

</LinearLayout>
