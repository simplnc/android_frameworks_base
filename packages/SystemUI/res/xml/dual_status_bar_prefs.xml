<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/dual_status_bar_settings_title"
        android:key="dual_status_bar_category">

        <SwitchPreference
            android:key="dual_status_bar_enabled"
            android:title="@string/dual_status_bar_enabled_title"
            android:summary="@string/dual_status_bar_enabled_summary"
            android:defaultValue="false" />

        <ListPreference
            android:key="dual_status_bar_layout"
            android:title="@string/dual_status_bar_layout_title"
            android:summary="@string/dual_status_bar_layout_summary"
            android:entries="@array/dual_status_bar_layout_entries"
            android:entryValues="@array/dual_status_bar_layout_values"
            android:defaultValue="standard"
            android:dependency="dual_status_bar_enabled" />

        <SwitchPreference
            android:key="dual_status_bar_show_network_traffic"
            android:title="@string/dual_status_bar_show_network_traffic_title"
            android:summary="@string/dual_status_bar_show_network_traffic_summary"
            android:defaultValue="true"
            android:dependency="dual_status_bar_enabled" />

        <SwitchPreference
            android:key="dual_status_bar_show_clock_secondary"
            android:title="@string/dual_status_bar_show_clock_secondary_title"
            android:summary="@string/dual_status_bar_show_clock_secondary_summary"
            android:defaultValue="true"
            android:dependency="dual_status_bar_enabled" />

    </PreferenceCategory>

</PreferenceScreen>
