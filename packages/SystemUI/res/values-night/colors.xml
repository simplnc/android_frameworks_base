    <color name="ambient_display_clock_primary">#FFFFFF</color> <!-- Ambient display clock -->
    <color name="ambient_display_clock_secondary">#BDBDBD</color> <!-- Ambient display secondary -->

    <!-- Phase 7: Advanced Lock Screen Customization Colors - Dark Mode -->
    <color name="lock_screen_widget_oneplus_bg">#1A237E</color> <!-- Darker OnePlus widget background -->
    <color name="lock_screen_widget_oneplus_border">#42A5F5</color> <!-- Brighter OnePlus widget border -->
