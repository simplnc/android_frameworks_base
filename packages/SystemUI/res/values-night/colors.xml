    <!-- Enhanced Lock Screen Colors - Dark Mode -->
    <color name="lock_screen_clock_oneplus_primary">#42A5F5</color> <!-- Brighter OnePlus blue -->
    <color name="lock_screen_clock_oneplus_secondary">#1A237E</color> <!-- Darker OnePlus blue -->
