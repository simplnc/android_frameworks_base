    <color name="qs_tile_press_overlay">#20FFFFFF</color>
    <color name="qs_tile_release_overlay">#10FFFFFF</color>
    <color name="notification_performance_shadow">#40000000</color>
    <color name="status_bar_performance_bg">#1C1C1C</color>
