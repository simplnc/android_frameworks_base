    <color name="toast_background_dark">#2C2C2C</color>
    <color name="toast_text_dark">#FFFFFF</color>
    <color name="power_menu_background_dark">#1A1A1A</color>
    <color name="app_install_progress_dark">#4CAF50</color>
    <color name="flash_notification_color">#FFFFFF</color>
    <color name="status_bar_enhanced_dark">#1A1A1A</color>
    
