<?xml version="1.0" encoding="utf-8"?>
<!-- Enhanced package installer layout with more information and better styling -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:theme="?android:attr/alertDialogTheme"
    android:paddingTop="8dp"
    android:paddingLeft="?android:attr/dialogPreferredPadding"
    android:paddingRight="?android:attr/dialogPreferredPadding"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- App Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/app_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/sym_def_app_icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material.Headline6"
                    android:textColor="?android:attr/textColorPrimary"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/app_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material.Body2"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/app_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material.Caption"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Installation Status Section -->
        <LinearLayout
            android:id="@+id/staging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="invisible"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material.Subtitle1"
                android:text="@string/message_staging"
                android:textColor="?android:attr/textColorPrimary" />

            <ProgressBar
                android:id="@+id/progress_indeterminate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:indeterminate="true" />

        </LinearLayout>

        <!-- Installing Section -->
        <LinearLayout
            android:id="@+id/installing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="invisible"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material.Subtitle1"
                android:text="@string/installing"
                android:textColor="?android:attr/textColorPrimary" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material.Caption"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginTop="4dp"
                android:text="0%" />

        </LinearLayout>

        <!-- App Information Section -->
        <LinearLayout
            android:id="@+id/app_info_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material.Subtitle1"
                android:text="@android:string/app_info"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <!-- Package Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="@android:string/app_info"
                    android:textAppearance="@style/TextAppearance.Material.Body2"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/package_name_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.Material.Body2"
                    android:textColor="?android:attr/textColorPrimary"
                    android:fontFamily="monospace"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Install Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@android:string/location_service"
                    android:textAppearance="@style/TextAppearance.Material.Body2"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_width="120dp" />

                <TextView
                    android:id="@+id/install_location_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.Material.Body2"
                    android:textColor="?android:attr/textColorPrimary" />

            </LinearLayout>

            <!-- Required Permissions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@android:string/permgrouplab_storage"
                    android:textAppearance="@style/TextAppearance.Material.Body2"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/permissions_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material.Body2"
                    android:textColor="?android:attr/textColorPrimary"
                    android:maxLines="3"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Confirmation Question -->
        <TextView
            android:id="@+id/install_confirm_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_confirm_question"
            android:textColor="?android:attr/textColorPrimary"
            android:visibility="invisible"
            android:scrollbars="vertical"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/install_confirm_question_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_confirm_question_update"
            android:textColor="?android:attr/textColorPrimary"
            android:visibility="invisible"
            android:scrollbars="vertical"
            android:paddingBottom="16dp" />

        <!-- Status Messages -->
        <TextView
            android:id="@+id/install_success"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_done"
            android:textColor="@color/install_success_color"
            android:visibility="invisible"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/install_failed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_failed"
            android:textColor="@color/install_error_color"
            android:visibility="invisible"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/install_failed_blocked"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_failed_blocked"
            android:textColor="@color/install_error_color"
            android:visibility="invisible"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/install_failed_conflict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_failed_conflict"
            android:textColor="@color/install_error_color"
            android:visibility="invisible"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/install_failed_incompatible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_failed_incompatible"
            android:textColor="@color/install_error_color"
            android:visibility="invisible"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/install_failed_invalid_apk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material.Body1"
            android:text="@string/install_failed_invalid_apk"
            android:textColor="@color/install_error_color"
            android:visibility="invisible"
            android:paddingBottom="16dp" />

    </LinearLayout>

</ScrollView>
