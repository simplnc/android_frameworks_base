<?xml version="1.0" encoding="utf-8"?>
<!--
     Basha Mobile - Enhanced Button State List Animator
     Based on dotOS 5.1 design guidelines and Material Design 3
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:duration="@integer/basha_animation_duration_short"
                android:propertyName="scaleX"
                android:valueTo="0.95"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="@integer/basha_animation_duration_short"
                android:propertyName="scaleY"
                android:valueTo="0.95"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="@integer/basha_animation_duration_short"
                android:propertyName="elevation"
                android:valueTo="0dp"
                android:valueType="floatType" />
        </set>
    </item>
    
    <!-- Default State -->
    <item>
        <set>
            <objectAnimator
                android:duration="@integer/basha_animation_duration_short"
                android:propertyName="scaleX"
                android:valueTo="1.0"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="@integer/basha_animation_duration_short"
                android:propertyName="scaleY"
                android:valueTo="1.0"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="@integer/basha_animation_duration_short"
                android:propertyName="elevation"
                android:valueTo="@dimen/basha_button_elevation"
                android:valueType="floatType" />
        </set>
    </item>
    
</selector>
