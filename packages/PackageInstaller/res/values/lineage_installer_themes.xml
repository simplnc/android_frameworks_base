<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- LineageOS Package Installer Themes - Using existing LineageOS theming system -->
    
    <!-- Main Package Installer Theme -->
    <style name="Theme.Lineage.PackageInstaller.Main" parent="@android:style/Theme.DeviceDefault.Dialog.Alert">
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:colorPrimary">?android:attr/colorPrimary</item>
        <item name="android:colorPrimaryDark">?android:attr/colorPrimaryDark</item>
        <item name="android:colorAccent">?android:attr/colorAccent</item>
        <item name="android:textColorPrimary">?android:attr/textColorPrimary</item>
        <item name="android:textColorSecondary">?android:attr/textColorSecondary</item>
        <item name="android:windowAnimationStyle">@style/LineageInstallerAnimation</item>
        <item name="android:dialogCornerRadius">?android:attr/dialogCornerRadius</item>
    </style>

    <!-- No Animation variant for installing/success screens -->
    <style name="Theme.Lineage.PackageInstaller.Main.NoAnim" parent="Theme.Lineage.PackageInstaller.Main">
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Animation style -->
    <style name="LineageInstallerAnimation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <!-- Button styles using LineageOS colors -->
    <style name="Widget.Lineage.Button.Positive" parent="@android:style/Widget.DeviceDefault.Button">
        <item name="android:background">@drawable/lineage_positive_button</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingHorizontal">24dp</item>
    </style>

    <style name="Widget.Lineage.Button.Negative" parent="@android:style/Widget.DeviceDefault.Button.Borderless">
        <item name="android:background">@drawable/lineage_negative_button</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingHorizontal">24dp</item>
    </style>

    <!-- App Icon Styles -->
    <style name="Widget.Lineage.AppIcon" parent="@android:style/Widget.DeviceDefault.ImageButton">
        <item name="android:scaleType">fitCenter</item>
        <item name="android:adjustViewBounds">true</item>
        <item name="android:background">@drawable/lineage_app_icon_container</item>
    </style>

    <style name="Widget.Lineage.AppIcon.Adaptive" parent="Widget.Lineage.AppIcon">
        <item name="android:background">@drawable/lineage_app_icon_adaptive</item>
    </style>
</resources>
