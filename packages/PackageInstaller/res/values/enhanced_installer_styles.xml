<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Enhanced Package Installer Styles -->
    <style name="Theme.EnhancedPackageInstaller" parent="@android:style/Theme.Material.Dialog.Alert">
        <item name="android:windowBackground">@color/enhanced_installer_background</item>
        <item name="android:colorPrimary">@android:color/holo_blue_bright</item>
        <item name="android:colorPrimaryDark">@android:color/holo_blue_dark</item>
        <item name="android:colorAccent">@android:color/holo_blue_bright</item>
        <item name="android:textColorPrimary">@color/enhanced_installer_text_primary</item>
        <item name="android:textColorSecondary">@color/enhanced_installer_text_secondary</item>
        <item name="android:windowAnimationStyle">@style/EnhancedInstallerAnimation</item>
    </style>

    <style name="TextAppearance.EnhancedInstaller.Title" parent="@android:style/TextAppearance.Material.Title">
        <item name="android:textColor">@color/enhanced_installer_text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.EnhancedInstaller.Subtitle" parent="@android:style/TextAppearance.Material.Subhead">
        <item name="android:textColor">@color/enhanced_installer_text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.EnhancedInstaller.Body" parent="@android:style/TextAppearance.Material.Body1">
        <item name="android:textColor">@color/enhanced_installer_text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.EnhancedInstaller.Caption" parent="@android:style/TextAppearance.Material.Caption">
        <item name="android:textColor">@color/enhanced_installer_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Enhanced Package Installer Animation -->
    <style name="EnhancedInstallerAnimation">
        <item name="android:windowEnterAnimation">@anim/enhanced_installer_enter</item>
        <item name="android:windowExitAnimation">@anim/enhanced_installer_exit</item>
    </style>
</resources>
