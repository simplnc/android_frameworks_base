<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Subtle shadow for depth -->
    <item android:top="1dp" android:left="1dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#08000000" />
        </shape>
    </item>
    
    <!-- Main circular background -->
    <item android:top="0dp" android:left="0dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="?android:attr/colorSurface" />
            <stroke 
                android:width="0.5dp"
                android:color="?android:attr/colorOutlineVariant" />
        </shape>
    </item>
    
</layer-list>

