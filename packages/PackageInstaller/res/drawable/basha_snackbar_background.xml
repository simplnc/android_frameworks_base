<?xml version="1.0" encoding="utf-8"?>
<!--
     Basha Mobile - Enhanced Snackbar Background
     Based on dotOS 5.1 design guidelines and Material Design 3
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Snackbar background color -->
    <solid android:color="@color/basha_snackbar_background" />
    
    <!-- Rounded corners -->
    <corners android:radius="8dp" />
    
    <!-- Subtle border -->
    <stroke 
        android:width="1dp" 
        android:color="@color/basha_outline_variant" />
        
</shape>
