<?xml version="1.0" encoding="utf-8"?>
<!--
     Basha Mobile - Enhanced Dialog Background
     Based on dotOS 5.1 design guidelines and Material Design 3
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Background color with transparency -->
    <solid android:color="@color/basha_dialog_background" />
    
    <!-- Rounded corners for modern look -->
    <corners android:radius="16dp" />
    
    <!-- Subtle border for definition -->
    <stroke 
        android:width="1dp" 
        android:color="@color/basha_outline_variant" />
    
    <!-- Drop shadow effect -->
    <padding 
        android:left="2dp" 
        android:top="2dp" 
        android:right="2dp" 
        android:bottom="2dp" />
        
</shape>
