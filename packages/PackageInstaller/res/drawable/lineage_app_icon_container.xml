<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Shadow layer -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape>
            <solid android:color="#10000000" />
            <corners android:radius="@dimen/config_buttonCornerRadius" />
        </shape>
    </item>
    
    <!-- Main background -->
    <item android:top="0dp" android:left="0dp" android:right="4dp" android:bottom="4dp">
        <shape>
            <solid android:color="?android:attr/colorSurface" />
            <corners android:radius="@dimen/config_buttonCornerRadius" />
            <stroke 
                android:width="1dp"
                android:color="?android:attr/colorOutline" />
        </shape>
    </item>
    
</layer-list>

