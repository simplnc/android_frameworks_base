<!-- Enhanced Network Security Configuration inspired by DivestOS -->
<network-security-config>
    <!-- Default configuration for all connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system CAs -->
            <certificates src="system"/>
            <!-- Trust user-added CAs only if explicitly enabled -->
            <certificates src="user" only-if="user_added_ca_enabled"/>
        </trust-anchors>
        
        <!-- Pin verification for enhanced security -->
        <pin-set>
            <!-- Google's backup pin (fallback) -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <!-- Add your preferred pin here -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
        </pin-set>
    </base-config>

    <!-- Strict configuration for sensitive domains -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">google.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">gstatic.com</domain>
        <domain includeSubdomains="true">android.com</domain>
        <domain includeSubdomains="true">googleusercontent.com</domain>
        
        <!-- Enhanced security for Google services -->
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
        
        <!-- Certificate pinning for Google services -->
        <pin-set>
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
        </pin-set>
    </domain-config>

    <!-- Debug configuration (only for debug builds) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>
